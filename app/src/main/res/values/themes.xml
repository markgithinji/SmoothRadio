<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Compose-optimized base theme -->
    <style name="Theme.SmoothRadio" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:forceDarkAllowed" tools:targetApi="q">false</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@color/red</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">true</item>

        <!-- Navigation bar -->
        <item name="android:navigationBarColor">@android:color/white</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">true</item>

        <!-- Window background -->
        <item name="android:windowBackground">@android:color/white</item>
    </style>

    <!-- Splash screen theme -->
    <style name="SplashScreenTheme" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/white</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splashscreen_icon</item>
        <item name="windowSplashScreenAnimationDuration">300</item>
        <item name="postSplashScreenTheme">@style/Theme.SmoothRadio</item>
        <item name="android:forceDarkAllowed" tools:targetApi="q">false</item>
    </style>

    <!-- Keep for any remaining XML views -->
    <style name="CustomTabText" parent="TextAppearance.Design.Tab">
        <item name="android:textSize">14sp</item>
        <item name="android:maxLines">1</item>
        <item name="fontFamily">@font/source_sans_pro</item>
    </style>
</resources>