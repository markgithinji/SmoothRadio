<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/clCategoryLayout"
    android:layout_width="wrap_content"
    android:layout_height="95dp"
    android:layout_marginTop="3dp">

    <ImageView
        android:id="@+id/ivCategoryBackground"
        android:layout_width="75dp"
        android:layout_height="30dp"
        android:background="@drawable/discovercontainer"
        android:foregroundGravity="center_horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.70" />


    <ImageView
        android:id="@+id/ivCategoryLogo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="5dp"
        android:background="@drawable/hopefm"
        android:foregroundGravity="center_horizontal"
        app:layout_constraintBottom_toBottomOf="@+id/ivCategoryBackground"
        app:layout_constraintEnd_toEndOf="@id/ivCategoryBackground"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toStartOf="@+id/ivCategoryBackground"
        app:layout_constraintTop_toTopOf="@id/ivCategoryBackground"
        app:layout_constraintVertical_bias="0.85" />

    <TextView
        android:id="@+id/tvCategoryChannelName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:ems="5"
        android:fontFamily="@font/source_sans_pro_semibold"
        android:gravity="center_horizontal"
        android:maxLength="15"
        android:maxLines="1"
        android:text="Kikuyu diaspora media"
        android:textColor="@color/black"
        android:textSize="12sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@id/ivCategoryBackground"
        app:layout_constraintEnd_toStartOf="@+id/ivCategoryFavrite"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toStartOf="@id/ivCategoryBackground"
        app:layout_constraintTop_toTopOf="@id/ivCategoryBackground"
        app:layout_constraintVertical_bias="1.0" />

    <ImageView
        android:id="@+id/ivCategoryFavrite"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="?android:attr/selectableItemBackground"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@+id/ivCategoryBackground"
        app:layout_constraintHorizontal_bias="1"
        app:layout_constraintStart_toStartOf="@+id/ivCategoryBackground"
        app:layout_constraintTop_toBottomOf="@+id/ivCategoryBackground"
        app:layout_constraintVertical_bias="1.0"
        app:srcCompat="@drawable/favorite_20px" />

    <ImageView
        android:id="@+id/ivCategoryPlay"
        android:layout_width="34dp"
        android:layout_height="34dp"
        android:layout_marginBottom="19dp"
        android:background="?android:attr/selectableItemBackground"
        android:padding="6dp"
        android:visibility="visible"
        app:layout_constraintBottom_toBottomOf="@+id/ivCategoryLogo"
        app:layout_constraintEnd_toEndOf="@+id/ivCategoryLogo"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toStartOf="@+id/ivCategoryLogo"
        app:layout_constraintTop_toTopOf="@+id/ivCategoryLogo"
        app:layout_constraintVertical_bias="1.0" />
</androidx.constraintlayout.widget.ConstraintLayout>